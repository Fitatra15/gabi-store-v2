PORT=3001
JWT_SECRET=change_me_to_random_secret
JWT_REFRESH_SECRET=change_me_to_another_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
NODE_ENV=production
DB_PATH=./database.sqlite
CORS_ORIGIN=*

